const RANKS=['A','K','Q','J','10','9','8','7','6','5','4','3','2'];
const SUITS=[['♠','black'],['♥','red'],['♦','red'],['♣','black']];
const STAGE_NAMES=['Префлоп','Флоп','Тёрн','Ривер'];
const STAGE_LABELS=['Твои карты (рука)','Флоп — 3 карты на столе','Тёрн — 4-я карта','Ривер — 5-я карта'];
let agentInited=false;
let aStage=0,aHole=[null,null],aFlop=[null,null,null],aTurn=null,aRiver=null;
let aHistory=[],aCurrentAdvice=null,aLoading=false;
let cModalSlot=null,cSelRank=null,cSelSuit=null;

function agentInit(){aStage=0;aHole=[null,null];aFlop=[null,null,null];aTurn=null;aRiver=null;aHistory=[];aCurrentAdvice=null;aLoading=false;renderAgent();}
function agentReset(){aStage=0;aHole=[null,null];aFlop=[null,null,null];aTurn=null;aRiver=null;aHistory=[];aCurrentAdvice=null;aLoading=false;renderAgent();}

function getUsed(){const s=new Set();[...aHole,...aFlop,aTurn,aRiver].filter(Boolean).forEach(c=>s.add(c.r+c.s));return s;}

function renderAgent(){
  updateStageDots();
  document.getElementById('agentStageLabel').textContent=STAGE_LABELS[aStage];
  renderHandDisplay();
  renderCardPicker();
  renderOddsPanel();
  const canGo=canAgentProceed()&&!aLoading;
  const ab=document.getElementById('agentAnalyzeBtn');
  ab.disabled=!canGo;
  ab.textContent=aLoading?'Думаю...':'Получить совет';
  const nb=document.getElementById('agentNextBtn');
  nb.style.display=(aCurrentAdvice&&aStage<3)?'block':'none';
  const box=document.getElementById('agentAdviceBox');
  if(aCurrentAdvice||aLoading){
    box.style.display='block';
    if(aLoading){
      document.getElementById('adviceVerdict').textContent='';
      document.getElementById('adviceText').innerHTML='<span style="color:rgba(212,175,55,0.4);font-size:12px;letter-spacing:0.1em">Анализирую...</span><span class="advice-cursor"></span>';
    } else if(aCurrentAdvice){
      const v=aCurrentAdvice.verdict;
      const vEl=document.getElementById('adviceVerdict');
      vEl.textContent=v==='play'?'▶ Играть':v==='fold'?'✕ Фолд':'◐ Осторожно';
      vEl.className='advice-verdict '+(v==='play'?'verdict-play':v==='fold'?'verdict-fold':'verdict-caution');
      document.getElementById('adviceText').innerHTML=aCurrentAdvice.text;
    }
  } else {
    box.style.display='none';
  }
  renderHistory();
}

function updateStageDots(){
  for(let i=0;i<4;i++){
    const el=document.getElementById('sd'+i);
    el.className='sdot'+(i<aStage?' done':i===aStage?' active':'');
  }
}

function canAgentProceed(){
  if(aStage===0)return aHole.every(Boolean);
  if(aStage===1)return aFlop.every(Boolean);
  if(aStage===2)return !!aTurn;
  if(aStage===3)return !!aRiver;
  return false;
}

function renderCardPicker(){
  const area=document.getElementById('cardPickerArea');
  let slots=[];
  if(aStage===0){slots=[{key:'h0',label:'Карта 1',card:aHole[0]},{key:'h1',label:'Карта 2',card:aHole[1]}];}
  else if(aStage===1){slots=[{key:'f0',label:'1',card:aFlop[0]},{key:'f1',label:'2',card:aFlop[1]},{key:'f2',label:'3',card:aFlop[2]}];}
  else if(aStage===2){slots=[{key:'t0',label:'Карта',card:aTurn}];}
  else if(aStage===3){slots=[{key:'r0',label:'Карта',card:aRiver}];}
  area.innerHTML=slots.map(sl=>{
    const c=sl.card;
    const isRed=c&&(c.s==='♥'||c.s==='♦');
    return `<div class="cslot">
      <div class="cslot-label">${sl.label}</div>
      <div class="cslot-card${c?' filled':''}${c&&isRed?' red-card':c?' black-card':''}" onclick="openCModal('${sl.key}')">
        ${c?`<span class="cv-r">${c.r}</span><span class="cv-s">${c.s}</span>`:`<span class="cv-plus">+</span>`}
      </div>
    </div>`;
  }).join('');
}

function renderHistory(){
  const h=document.getElementById('agentHistory');
  if(!aHistory.length){h.innerHTML='';return;}
  h.innerHTML=aHistory.map(x=>`<div class="hist-item"><div class="hist-stage">${x.stage}</div><div class="hist-text">${x.text}</div></div>`).join('');
}

function openCModal(slot){
  cModalSlot=slot;cSelRank=null;cSelSuit=null;
  const used=getUsed();
  const rr=document.getElementById('cmodalRanks');
  rr.innerHTML=RANKS.map(r=>`<button class="cr-btn" data-r="${r}" ${used.has(r+(cSelSuit||''))&&false?'disabled':''} onclick="selRank('${r}')">${r}</button>`).join('');
  const sr=document.getElementById('cmodalSuits');
  sr.innerHTML=SUITS.map(([s,c])=>`<button class="cs-btn${c==='red'?' red-suit':''}" data-s="${s}" onclick="selSuit('${s}')">${s}</button>`).join('');
  document.getElementById('cmodalConfirm').disabled=true;
  document.getElementById('cmodalBg').style.display='flex';
}
function closeCModal(){document.getElementById('cmodalBg').style.display='none';cSelRank=null;cSelSuit=null;}

function selRank(r){
  cSelRank=r;
  document.querySelectorAll('.cr-btn').forEach(b=>b.classList.toggle('sel',b.dataset.r===r));
  checkCModal();
}
function selSuit(s){
  cSelSuit=s;
  document.querySelectorAll('.cs-btn').forEach(b=>b.classList.toggle('sel',b.dataset.s===s));
  checkCModal();
