function confirmCard(){
  const card={r:cSelRank,s:cSelSuit};
  const slot=cModalSlot;
  if(slot==='h0')aHole[0]=card;
  else if(slot==='h1')aHole[1]=card;
  else if(slot==='f0')aFlop[0]=card;
  else if(slot==='f1')aFlop[1]=card;
  else if(slot==='f2')aFlop[2]=card;
  else if(slot==='t0')aTurn=card;
  else if(slot==='r0')aRiver=card;
  aCurrentAdvice=null;
  closeCModal();
