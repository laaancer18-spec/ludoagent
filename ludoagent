function checkCModal(){
  const used=getUsed();
  const btn=document.getElementById('cmodalConfirm');
  if(cSelRank&&cSelSuit){
    const taken=used.has(cSelRank+cSelSuit);
    btn.disabled=taken;
    btn.textContent=taken?'Уже использована':'Выбрать';
  } else {btn.disabled=true;btn.textContent='Выбрать';}
